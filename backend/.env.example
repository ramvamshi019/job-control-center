# ---- Job Control Center : environment template ----
# Copy this file to ".env" in the SAME folder (backend/.env) and edit values.
#   cp .env.example .env
#
# NOTHING here is required for the MVP to run. The system works fully offline
# with rule-based scoring/tailoring. API keys only ENRICH resume notes &
# cover letters when present.

# --- Database ---
# Path is relative to the backend/ folder when you run scripts from there.
DATABASE_URL=sqlite:///./data/jobs.db

# --- AI provider (optional) ---
# Leave AI_PROVIDER empty (or "none") to use built-in rule-based generation.
# Options: none | anthropic | openai
AI_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Default models used IF a provider is enabled:
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o-mini

# --- Crawler behavior ---
# Be polite to career sites. Delay (seconds) between company requests.
CRAWL_DELAY_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=JobControlCenter/1.0 (+personal-job-search; respectful crawler)

# --- Scoring ---
# Jobs at/above this score appear in "Today's Best Jobs".
MIN_GOOD_SCORE=75

# --- Filters & retention (your confirmed policies) ---
US_ONLY=true
# Delete jobs whose POSTED date is older than this many days (actioned jobs kept).
PRUNE_DAYS=10
# Model used only if AI tailoring is enabled (cheaper than the global model).
RESUME_MODEL=claude-haiku-4-5

# --- Candidate profile (used by scoring + tailoring) ---
# Comma-separated skills from YOUR resume. Edit these!
MY_SKILLS=python,sql,aws,azure,gcp,spark,airflow,kafka,snowflake,docker,kubernetes,terraform,etl,pandas,fastapi,postgresql,databricks
MY_TARGET_ROLES=data engineer,cloud engineer,software engineer
MY_WORK_AUTH=F-1 OPT (STEM), needs H-1B sponsorship later

# --- Dashboard ---
# Where the dashboard finds the backend API.
API_BASE_URL=http://127.0.0.1:8000
